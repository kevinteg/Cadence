var cli = cac("cadence");
cli.command("scan", "Show a tabular summary of the repo snapshot").option("--root <path>", "Repo root (default: cwd or auto-detect)").option("--json", "Emit the full Snapshot as JSON").action(async (opts) => {
  const repoRoot = await resolveRepoRoot(opts.root);
  const snapshot = await scan(repoRoot);
