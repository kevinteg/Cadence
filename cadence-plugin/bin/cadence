// src/write/edits.ts
import path16 from "node:path";
import { readdir, readFile as readFile8 } from "node:fs/promises";
import { existsSync as existsSync8 } from "node:fs";

// src/write/checklist.ts
var ITEM_RE2 = /^(\s*-\s+\[)([ xX])(\]\s+)(.+?)(\s*)$/;
function toggleChecklistItem(body, sectionName, match, checked) {
  const result = mutateInSection(body, sectionName, (line, itemIndex, item) => {
    if (item === void 0) return null;
    const isMatch = typeof match === "number" ? itemIndex === match : item.text.toLowerCase().includes(match.toLowerCase());
    if (!isMatch) return null;
    const re = ITEM_RE2.exec(line);
    if (!re) return null;
    const [, lead, , close, rest, trail] = re;
    return {
      newLine: `${lead}${checked ? "x" : " "}${close}${rest}${trail}`,
      matchedText: item.text
    };
  });
  if (!result) {
    throw new Error(
      `no checklist item matched "${match}" in section "${sectionName}"`
    );
  }
  return result;
}
function appendChecklistItem(body, sectionName, text, checked = false) {
  const sectionRe = headerRegex(sectionName);
  const lines = body.split("\n");
  const startIdx = lines.findIndex((l) => sectionRe.test(l));
  if (startIdx < 0) {
    const trailing = lines[lines.length - 1] === "" ? "" : "\n";
    return body.replace(/\n+$/, "") + `

## ${capitalize(sectionName)}
- [${checked ? "x" : " "}] ${text}` + trailing;
  }
  let endIdx = lines.length;
  for (let i = startIdx + 1; i < lines.length; i++) {
    if (/^##\s+/.test(lines[i] ?? "")) {
      endIdx = i;
      break;
    }
  }
  while (endIdx > startIdx + 1 && (lines[endIdx - 1] ?? "").trim() === "") {
    endIdx--;
  }
  const before = lines.slice(0, endIdx);
  const after = lines.slice(endIdx);
  before.push(`- [${checked ? "x" : " "}] ${text}`);
  return [...before, ...after].join("\n");
}
function mutateInSection(body, sectionName, fn) {
  const sectionRe = headerRegex(sectionName);
  const lines = body.split("\n");
  let inSection = false;
  let itemIndex = 0;
  let result = null;
  for (let i = 0; i < lines.length; i++) {
    const line = lines[i] ?? "";
    if (sectionRe.test(line)) {
      inSection = true;
      itemIndex = 0;
      continue;
    }
    if (inSection && /^##\s+/.test(line)) {
      inSection = false;
    }
    if (!inSection) continue;
    const re = ITEM_RE2.exec(line);
    if (!re) continue;
    const text = re[4] ?? "";
    const checked = (re[2] ?? " ").toLowerCase() === "x";
    const out = fn(line, itemIndex, { text, checked });
    itemIndex++;
    if (out) {
      lines[i] = out.newLine;
      result = { body: lines.join("\n"), matched: out.matchedText };
      return result;
    }
  }
  return result;
}
function headerRegex(sectionName) {
  const escaped = sectionName.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
  return new RegExp(`^##\\s+${escaped}\\s*$`, "i");
}
function capitalize(s) {
  return s.charAt(0).toUpperCase() + s.slice(1);
}
function appendParagraphToSection(body, sectionName, text) {
  const sectionRe = headerRegex(sectionName);
  const lines = body.split("\n");
  const startIdx = lines.findIndex((l) => sectionRe.test(l));
  if (startIdx < 0) {
    const trailing = body.endsWith("\n") ? "" : "\n";
    return body.replace(/\n+$/, "") + `

## ${capitalize(sectionName)}

${text}` + trailing;
  }
  let endIdx = lines.length;
  for (let i = startIdx + 1; i < lines.length; i++) {
    if (/^##\s+/.test(lines[i] ?? "")) {
      endIdx = i;
      break;
    }
  }
  while (endIdx > startIdx + 1 && (lines[endIdx - 1] ?? "").trim() === "") {
    endIdx--;
  }
  const before = lines.slice(0, endIdx);
  const after = lines.slice(endIdx);
  if (endIdx > startIdx + 1 && (before[before.length - 1] ?? "").trim() !== "") {
    before.push("");
  }
  before.push(text);
  return [...before, ...after].join("\n");
}
function computeProjectProgress(body) {
  return {
    dodProgress: progressFor(body, "Definition of Done"),
    actionProgress: progressFor(body, "Actions")
  };
}
function progressFor(body, sectionName) {
  const sectionRe = headerRegex(sectionName);
  const lines = body.split("\n");
  let inSection = false;
  let total = 0;
  let done = 0;
  for (const line of lines) {
    if (sectionRe.test(line)) {
      inSection = true;
      continue;
    }
    if (inSection && /^##\s+/.test(line)) inSection = false;
    if (!inSection) continue;
    const m = ITEM_RE2.exec(line);
    if (!m) continue;
    total++;
    if ((m[2] ?? " ").toLowerCase() === "x") done++;
  }
  return { done, total };
}

// src/write/edits.ts
async function setProjectStatus(repoRoot, opts) {
  const filePath = await locateProject(repoRoot, opts.id, opts.pursuit);
  const now = opts.now ?? /* @__PURE__ */ new Date();
  await mutateFrontmatter(filePath, (data, body) => {
    data["status"] = opts.status;
    if (opts.status === "dropped") {
      if (!opts.reason) {
        throw new Error("dropping a project requires a reason");
      }
      data["dropped_reason"] = opts.reason;
      data["dropped_at"] = isoTimestamp(now);
    }
    return { data, body };
  });
  const result = {
    path: path16.relative(repoRoot, filePath)
  };
  if (opts.include_pursuit) {
    result.pursuit = await summarizePursuit(repoRoot, filePath);
  }
  return result;
}
async function summarizePursuit(repoRoot, projectFilePath) {
  const projectsDir = path16.dirname(projectFilePath);
  const pursuitDir = path16.dirname(projectsDir);
  const pursuitId = path16.basename(pursuitDir);
  const projects = [];
  if (existsSync8(projectsDir)) {
    for (const entry of await readdir(projectsDir, { withFileTypes: true })) {
      if (!entry.isFile() || !entry.name.endsWith(".md")) continue;
      const file = path16.join(projectsDir, entry.name);
      const text = await readFile8(file, "utf8");
      const { data } = parseFrontmatter(text);
      const id = String(data["id"] ?? entry.name.replace(/\.md$/, ""));
      const status = String(data["status"] ?? "active");
      projects.push({ id, status });
    }
  }
  const done = projects.filter(
    (p) => p.status === "done" || p.status === "dropped"
  ).length;
  const total = projects.length;
  return {
    id: pursuitId,
    projects,
    done,
    total,
    allResolved: total > 0 && done === total
  };
}
async function setIdeaState(repoRoot, opts) {
  const filePath = await locateIdea(repoRoot, opts.id, opts.parent);
  const now = opts.now ?? /* @__PURE__ */ new Date();
  await mutateFrontmatter(filePath, (data, body) => {
    data["state"] = opts.state;
    if (opts.state === "developed") {
      if (!data["developed_at"]) data["developed_at"] = dateString(now);
    } else if (opts.state === "promoted") {
      if (!opts.promoted_to) {
        throw new Error("promoting an idea requires --promoted-to");
      }
      data["promoted_to"] = opts.promoted_to;
    } else if (opts.state === "closed") {
      if (!opts.reason) {
        throw new Error("closing an idea requires a reason");
      }
      data["closed_reason"] = opts.reason;
    } else if (opts.state === "moved") {
      if (opts.new_parent) data["parent"] = opts.new_parent;
    }
    return { data, body };
  });
  return { path: path16.relative(repoRoot, filePath) };
}
async function checkItem(repoRoot, opts) {
  const filePath = await locateProject(repoRoot, opts.project, opts.pursuit);
  const checked = opts.checked ?? true;
  const sectionName = opts.section === "dod" ? "Definition of Done" : "Actions";
  let matched = "";
  let promoted = false;
  let finalBody = "";
  await mutateFrontmatter(filePath, (data, body) => {
    const result = toggleChecklistItem(body, sectionName, opts.match, checked);
    matched = result.matched;
    let nextBody = result.body;
    if (opts.note && checked) {
      nextBody = appendNote(nextBody, sectionName, matched, opts.note);
    }
    if (opts.section === "action" && checked && data["status"] === "on_hold") {
      data["status"] = "active";
      promoted = true;
    }
    finalBody = nextBody;
    return { data, body: nextBody };
  });
  const progress2 = computeProjectProgress(finalBody);
  return {
    path: path16.relative(repoRoot, filePath),
    matched,
    ...promoted ? { promoted: true } : {},
    ...progress2
  };
}
async function checkItems(repoRoot, opts) {
  const filePath = await locateProject(repoRoot, opts.project, opts.pursuit);
  const checked = opts.checked ?? true;
  const sectionName = opts.section === "dod" ? "Definition of Done" : "Actions";
  const matched = [];
  let promoted = false;
  let finalBody = "";
  await mutateFrontmatter(filePath, (data, body) => {
    let nextBody = body;
    for (const match of opts.matches) {
      const result = toggleChecklistItem(nextBody, sectionName, match, checked);
      matched.push(result.matched);
      nextBody = result.body;
    }
    if (opts.section === "action" && checked && data["status"] === "on_hold" && opts.matches.length > 0) {
      data["status"] = "active";
      promoted = true;
    }
    finalBody = nextBody;
    return { data, body: nextBody };
  });
  const progress2 = computeProjectProgress(finalBody);
  return {
    path: path16.relative(repoRoot, filePath),
    matched,
    ...promoted ? { promoted: true } : {},
    ...progress2
  };
}
async function addItem(repoRoot, opts) {
  const filePath = await locateProject(repoRoot, opts.project, opts.pursuit);
  const sectionName = opts.section === "dod" ? "Definition of Done" : opts.section === "action" ? "Actions" : "Notes";
  let finalBody = "";
  await mutateFrontmatter(filePath, (data, body) => {
    const nextBody = opts.section === "notes" ? appendParagraphToSection(body, sectionName, opts.text) : appendChecklistItem(body, sectionName, opts.text, opts.checked ?? false);
    finalBody = nextBody;
    return { data, body: nextBody };
  });
  const progress2 = computeProjectProgress(finalBody);
  return {
    path: path16.relative(repoRoot, filePath),
    ...progress2
  };
}
async function addItems(repoRoot, opts) {
  const filePath = await locateProject(repoRoot, opts.project, opts.pursuit);
  const sectionName = opts.section === "dod" ? "Definition of Done" : opts.section === "action" ? "Actions" : "Notes";
  let finalBody = "";
  await mutateFrontmatter(filePath, (data, body) => {
    let nextBody = body;
    for (const text of opts.texts) {
      nextBody = opts.section === "notes" ? appendParagraphToSection(nextBody, sectionName, text) : appendChecklistItem(
        nextBody,
        sectionName,
        text,
        opts.checked ?? false
      );
    }
    finalBody = nextBody;
    return { data, body: nextBody };
  });
  const progress2 = computeProjectProgress(finalBody);
  return {
    path: path16.relative(repoRoot, filePath),
    added: opts.texts.length,
    ...progress2
  };
}
async function addWaitingFor(repoRoot, opts) {
  const filePath = await locateProject(repoRoot, opts.project, opts.pursuit);
  await mutateFrontmatter(filePath, (data, body) => {
    const list = Array.isArray(data["waiting_for"]) ? [...data["waiting_for"]] : [];
    list.push({
      person: opts.person,
      what: opts.what,
      expected: opts.expected,
      flagged: false
    });
    data["waiting_for"] = list;
    return { data, body };
  });
  return { path: path16.relative(repoRoot, filePath) };
}
async function flagWaitingFor(repoRoot, opts) {
  const filePath = await locateProject(repoRoot, opts.project, opts.pursuit);
  const flagged = opts.flagged ?? true;
  let matched = { person: "", what: "" };
  await mutateFrontmatter(filePath, (data, body) => {
    const list = Array.isArray(data["waiting_for"]) ? [...data["waiting_for"]] : [];
    let foundIndex = -1;
    if (typeof opts.match === "number") {
      foundIndex = opts.match;
    } else {
      const lower = opts.match.toLowerCase();
      foundIndex = list.findIndex((w) => {
        const person = String(w["person"] ?? "").toLowerCase();
        const what = String(w["what"] ?? "").toLowerCase();
        return person.includes(lower) || what.includes(lower);
      });
    }
    if (foundIndex < 0 || foundIndex >= list.length) {
      throw new Error(`no waiting_for matched "${opts.match}"`);
    }
    const item = list[foundIndex] ?? {};
    item["flagged"] = flagged;
    list[foundIndex] = item;
    matched = {
      person: String(item["person"] ?? ""),
      what: String(item["what"] ?? "")
    };
    data["waiting_for"] = list;
    return { data, body };
  });
  return { path: path16.relative(repoRoot, filePath), matched };
}
async function locateProject(repoRoot, projectId, pursuitHint) {
  if (pursuitHint) {
    const file = resolveProjectFile(repoRoot, pursuitHint, projectId);
    if (!file) {
      throw new Error(`project not found: ${pursuitHint}/${projectId}`);
    }
    return file;
  }
  const roots = ["pursuits", "pursuits/_someday", "pursuits/_archived"];
  for (const root of roots) {
    const absRoot = path16.join(repoRoot, root);
    if (!existsSync8(absRoot)) continue;
    for (const pursuit of await readdir(absRoot, { withFileTypes: true })) {
      if (!pursuit.isDirectory()) continue;
      const candidate = path16.join(
        absRoot,
        pursuit.name,
        "projects",
        `${projectId}.md`
      );
      if (existsSync8(candidate)) return candidate;
    }
  }
  throw new Error(
    `project not found: ${projectId} (pass --pursuit to disambiguate)`
  );
}
async function locateIdea(repoRoot, ideaId, parentHint) {
  if (parentHint) {
    const file = resolveIdeaFile(repoRoot, parentHint, ideaId);
    if (!file) throw new Error(`idea not found: ${parentHint}/${ideaId}`);
    return file;
  }
  const roots = ["pursuits", "pursuits/_someday", "pursuits/_archived"];
  for (const root of roots) {
    const absRoot = path16.join(repoRoot, root);
    if (!existsSync8(absRoot)) continue;
    for (const pursuit of await readdir(absRoot, { withFileTypes: true })) {
      if (!pursuit.isDirectory()) continue;
      const candidate = path16.join(
        absRoot,
        pursuit.name,
        "ideas",
        `${ideaId}.md`
      );
      if (existsSync8(candidate)) return candidate;
    }
  }
  throw new Error(
    `idea not found: ${ideaId} (pass --parent to disambiguate)`
  );
}
function appendNote(body, sectionName, itemText, note) {
  const lines = body.split("\n");
  const sectionRe = new RegExp(`^##\\s+${escapeRe(sectionName)}\\s*$`, "i");
  let inSection = false;
  for (let i = 0; i < lines.length; i++) {
    const line = lines[i] ?? "";
    if (sectionRe.test(line)) {
      inSection = true;
      continue;
    }
    if (inSection && /^##\s+/.test(line)) inSection = false;
    if (!inSection) continue;
    if (line.includes(itemText)) {
      const indent = (/^(\s*)/.exec(line)?.[1] ?? "") + "  ";
      lines.splice(i + 1, 0, `${indent}- ${note}`);
      return lines.join("\n");
    }
  }
  return body;
}
function escapeRe(s) {
  return s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

// src/write/move.ts
import path17 from "node:path";
import { existsSync as existsSync9 } from "node:fs";
async function movePursuit(repoRoot, opts) {
  const from = resolvePursuitDir(repoRoot, opts.id);
  if (!from) throw new Error(`pursuit not found: ${opts.id}`);
  const targetParent = opts.to === "active" ? path17.join(repoRoot, "pursuits") : opts.to === "someday" ? path17.join(repoRoot, "pursuits/_someday") : path17.join(repoRoot, "pursuits/_archived");
  const to = path17.join(targetParent, opts.id);
  if (path17.resolve(from) === path17.resolve(to)) {
    return {
      from: path17.relative(repoRoot, from),
      to: path17.relative(repoRoot, to)
    };
  }
  if (existsSync9(to)) {
    throw new Error(`destination already exists: ${path17.relative(repoRoot, to)}`);
  }
  await moveDir(from, to);
  await mutateFrontmatter(path17.join(to, "pursuit.md"), (data, body) => {
    data["status"] = opts.to;
    return { data, body };
  });
  return {
    from: path17.relative(repoRoot, from),
    to: path17.relative(repoRoot, to)
  };
}

// src/tip/library.ts
import { existsSync as existsSync11, readFileSync as readFileSync3 } from "node:fs";
import path19 from "node:path";
import { fileURLToPath } from "node:url";

// src/tip/state.ts
import { existsSync as existsSync10, readFileSync as readFileSync2, mkdirSync as mkdirSync2, writeFileSync as writeFileSync2 } from "node:fs";
import path18 from "node:path";
var STATE_FILENAME = "tip-state.json";
function statePath(repoRoot) {
  return path18.join(repoRoot, ".cadence", STATE_FILENAME);
}
function readTipState(repoRoot) {
  const filePath = statePath(repoRoot);
  if (!existsSync10(filePath)) {
    return { version: 1, tips: {} };
  }
  try {
    const raw = readFileSync2(filePath, "utf8");
    const parsed = JSON.parse(raw);
    if (parsed.version !== 1 || typeof parsed.tips !== "object") {
      return { version: 1, tips: {} };
    }
    return parsed;
  } catch {
    return { version: 1, tips: {} };
  }
}
function writeTipState(repoRoot, state) {
  const dir = path18.join(repoRoot, ".cadence");
  if (!existsSync10(dir)) {
    mkdirSync2(dir, { recursive: true });
  }
  writeFileSync2(statePath(repoRoot), JSON.stringify(state, null, 2) + "\n");
}
function recordShow(repoRoot, tipId, now = /* @__PURE__ */ new Date()) {
  const state = readTipState(repoRoot);
  const prior = state.tips[tipId];
  const updated = {
    show_count: (prior?.show_count ?? 0) + 1,
    last_shown: now.toISOString()
  };
  state.tips[tipId] = updated;
  writeTipState(repoRoot, state);
  return updated;
}
function isEligible(state, tipId, cap, now = /* @__PURE__ */ new Date()) {
  const record = state.tips[tipId];
  if (!record) {
    return { eligible: true, reason: "never-shown" };
  }
  if (cap.lifetime_max !== void 0 && record.show_count >= cap.lifetime_max) {
    return { eligible: false, reason: "lifetime-max" };
  }
  const lastShown = new Date(record.last_shown);
  const elapsedMs = now.getTime() - lastShown.getTime();
  if (cap.cool_down_minutes !== void 0) {
    const requiredMs = cap.cool_down_minutes * 60 * 1e3;
    if (elapsedMs < requiredMs) {
      return {
        eligible: false,
        reason: "cool-down-minutes",
        next_eligible_at: new Date(
          lastShown.getTime() + requiredMs
        ).toISOString()
      };
    }
  }
  if (cap.cool_down_days !== void 0) {
    const requiredMs = cap.cool_down_days * 24 * 60 * 60 * 1e3;
    if (elapsedMs < requiredMs) {
      return {
        eligible: false,
        reason: "cool-down-days",
        next_eligible_at: new Date(
          lastShown.getTime() + requiredMs
        ).toISOString()
      };
    }
  }
  return { eligible: true, reason: "eligible" };
}
function resetTips(repoRoot, predicate) {
  const state = readTipState(repoRoot);
  const cleared = [];
  for (const id of Object.keys(state.tips)) {
    if (predicate(id)) {
      delete state.tips[id];
      cleared.push(id);
    }
  }
  writeTipState(repoRoot, state);
  return cleared;
}

// src/tip/library.ts
var VALID_TYPES = ["quote", "skill-teaching", "verb-hint"];
var VALID_TONES = ["framing", "directive", "diagnostic", "structural"];
var VALID_WEIGHTS = ["low", "normal", "high"];
function asStringArray(v) {
  if (!Array.isArray(v)) return [];
  return v.filter((x) => typeof x === "string");
}
function asNumber(v) {
  if (typeof v === "number" && Number.isFinite(v)) return v;
  return void 0;
}
function asString(v) {
  if (typeof v === "string" && v.length > 0) return v;
  return void 0;
}
function libraryPath() {
  const here = fileURLToPath(import.meta.url);
  return path19.resolve(path19.dirname(here), "..", "tips", "library.yaml");
}
function readLibrary(libPath) {
  const filePath = libPath ?? libraryPath();
  if (!existsSync11(filePath)) {
    return { version: 1, tips: [] };
  }
  const raw = readFileSync3(filePath, "utf8");
  const doc = jsYaml.load(raw);
  if (!doc || typeof doc !== "object") {
    return { version: 1, tips: [] };
  }
  if (doc.version !== 1 || !Array.isArray(doc.tips)) {
    return { version: 1, tips: [] };
  }
  const tips = [];
  for (const r of doc.tips) {
    const id = asString(r.id);
    const type2 = VALID_TYPES.find((t) => t === r.type);
    const content = asString(r.content);
    const triggers = asStringArray(r.triggers);
    if (!id || !type2 || !content || triggers.length === 0) continue;
    const tone = VALID_TONES.find((t) => t === r.tone) ?? "structural";
    const weight = VALID_WEIGHTS.find((w) => w === r.weight) ?? "normal";
    const frequency = {};
    if (r.frequency && typeof r.frequency === "object") {
      const cdm = asNumber(r.frequency.cool_down_minutes);
      const cdd = asNumber(r.frequency.cool_down_days);
      const lim = asNumber(r.frequency.lifetime_max);
      if (cdm !== void 0) frequency.cool_down_minutes = cdm;
      if (cdd !== void 0) frequency.cool_down_days = cdd;
      if (lim !== void 0) frequency.lifetime_max = lim;
    }
    const tip = {
      id,
      type: type2,
      content: content.replace(/\s+$/u, ""),
      triggers,
      tone,
      weight,
      frequency
    };
    const attribution = asString(r.attribution);
    if (attribution) tip.attribution = attribution;
    const tags = asStringArray(r.tags);
    if (tags.length > 0) tip.tags = tags;
    tips.push(tip);
  }
  return { version: 1, tips };
}
function matchingTips(library, options2) {
  const active = new Set(options2.triggers);
  const candidates = [];
  for (const tip of library.tips) {
    const matched = tip.triggers.filter((t) => active.has(t));
    if (matched.length === 0) continue;
    if (options2.types && !options2.types.includes(tip.type)) continue;
    if (options2.tones && !options2.tones.includes(tip.tone)) continue;
    candidates.push({ tip, matched_triggers: matched });
  }
  return candidates;
}
function eligibleTips(library, state, options2) {
  const now = options2.now ?? /* @__PURE__ */ new Date();
  return matchingTips(library, options2).filter((c) => {
    return isEligible(state, c.tip.id, c.tip.frequency, now).eligible;
  });
}
function selectTip(library, state, options2) {
  const eligible = eligibleTips(library, state, options2);
  if (eligible.length === 0) return null;
  const weightValue = (w) => w === "high" ? 3 : w === "low" ? 1 : 2;
  const maxWeight = Math.max(
    ...eligible.map((c) => weightValue(c.tip.weight))
  );
  const topTier = eligible.filter(
    (c) => weightValue(c.tip.weight) === maxWeight
  );
  topTier.sort((a, b) => {
    const ra = state.tips[a.tip.id];
    const rb = state.tips[b.tip.id];
    if (!ra && rb) return -1;
    if (ra && !rb) return 1;
    if (!ra && !rb) return 0;
    const ta = new Date(ra.last_shown).getTime();
    const tb = new Date(rb.last_shown).getTime();
    return ta - tb;
  });
  return topTier[0] ?? null;
}
function tipStatus(library, state, now = /* @__PURE__ */ new Date()) {
  return library.tips.map((tip) => {
    const elig = isEligible(state, tip.id, tip.frequency, now);
    const record = state.tips[tip.id];
    const entry = {
      id: tip.id,
      type: tip.type,
      content_preview: tip.content.split("\n")[0]?.slice(0, 80) ?? "",
      triggers: tip.triggers,
      show_count: record?.show_count ?? 0,
      eligible_now: elig.eligible
    };
    if (record?.last_shown) entry.last_shown = record.last_shown;
    if (elig.next_eligible_at) entry.next_eligible_at = elig.next_eligible_at;
    return entry;
  });
}

